# =============================================================
#  VIRSA MULTI-VENDOR MARKETPLACE — ENVIRONMENT VARIABLES
#  Copy this file to .env.local and fill in your real values.
#  See doc/security-and-backup.md for where to get each key.
#  DO NOT put real credentials in this file — it is committed to Git.
# =============================================================

# ─────────────────────────────────────────────────────────────
#  SUPABASE — PRIMARY PROJECT (live traffic)
#  Get from: supabase.com → your project → Settings → API
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PRIMARY_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_primary_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_primary_service_role_key_here
SUPABASE_PRIMARY_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PRIMARY_PROJECT_ID.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
#  SUPABASE — BACKUP PROJECT (standby / failover, Singapore)
#  Get from: supabase.com → virsa-backup project → Settings → API
# ─────────────────────────────────────────────────────────────

SUPABASE_BACKUP_URL=https://YOUR_BACKUP_PROJECT_ID.supabase.co
SUPABASE_BACKUP_ANON_KEY=your_backup_anon_key_here
SUPABASE_BACKUP_SERVICE_ROLE_KEY=your_backup_service_role_key_here
SUPABASE_BACKUP_DB_HOST=db.YOUR_BACKUP_PROJECT_ID.supabase.co
SUPABASE_BACKUP_DB_PASSWORD=your_backup_db_password_here

# ─────────────────────────────────────────────────────────────
#  MYSQL — FINANCIAL DATABASE (Hostinger)
#  Get from: Hostinger control panel → MySQL Databases
# ─────────────────────────────────────────────────────────────

DATABASE_URL=mysql://YOUR_MYSQL_USERNAME:YOUR_MYSQL_PASSWORD@YOUR_MYSQL_HOST:3306/YOUR_MYSQL_DATABASE

# ─────────────────────────────────────────────────────────────
#  DATA ENCRYPTION
#  Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────

ENCRYPTION_KEY=your_64_char_hex_string_here

# ─────────────────────────────────────────────────────────────
#  EMAIL — TRANSACTIONAL + SYSTEM ALERTS (Resend)
#  Get from: resend.com → API Keys
# ─────────────────────────────────────────────────────────────

RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@virsasharedbypakistan.com
ALERT_EMAIL=admin@virsasharedbypakistan.com

# ─────────────────────────────────────────────────────────────
#  RATE LIMITING — UPSTASH REDIS
#  Get from: upstash.com → your database → REST API
# ─────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─────────────────────────────────────────────────────────────
#  APPLICATION CONFIG
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=https://virsasharedbypakistan.com
ALLOWED_ORIGIN=https://virsasharedbypakistan.com
NODE_ENV=production
