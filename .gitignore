# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.kiro
.agents
.vscode
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real secrets, keep the example template
.env
.env.local
.env.development
.env.production
.env.staging
# .env.example is intentionally NOT ignored — commit it to Git

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
